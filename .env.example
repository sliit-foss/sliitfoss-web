# Resend API key (required for contact form delivery)
# Get one at https://resend.com
RESEND_API_KEY=

# Sender address. Must be on a verified Resend domain.
# Defaults to "SLIIT FOSS <onboarding@resend.dev>" for testing.
RESEND_FROM_EMAIL=

# Recipient address for contact form submissions.
# Defaults to siteConfig.contact.email.
RESEND_TO_EMAIL=

# Google Apps Script web app URL that appends membership submissions to the Sheet.
# See scripts/sheets-webhook.gs for setup.
SHEETS_WEBHOOK_URL=

# Shared secret matching the SHEETS_WEBHOOK_TOKEN script property on the Apps Script.
SHEETS_WEBHOOK_TOKEN=
