# Resend API key (required for contact + membership form delivery)
# Get one at https://resend.com
RESEND_API_KEY=

# Sender address. Must be on a verified Resend domain.
# Defaults to "SLIIT FOSS <onboarding@resend.dev>" for testing.
RESEND_FROM_EMAIL=

# Recipient address for form submissions.
# Defaults to siteConfig.contact.email.
RESEND_TO_EMAIL=
